{
  "manifest_version": 3,
  "name": "Zabbix NOC Alerter",
  "version": "0.1.1",
  "description": "Sound and browser notification alerts for new Zabbix problems. Uses your open session, no token, nothing hardcoded.",
  "author": "opastorello",
  "permissions": [
    "storage",
    "cookies",
    "notifications",
    "offscreen",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html"
}
